{
  "name": "api",
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist --external=sharp",
    "dev": "bun --watch src/index.ts",
    "db:migrate": "kysely migrate",
    "db:generate": "kysely-codegen --out-file ./src/lib/db.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fmt": "prettier . --write"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.5.6",
    "hono": "^4.12.9",
    "isbn": "workspace:*",
    "kysely": "^0.28.14",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "^1.3.11",
    "@types/pg": "^8.20.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.20.0",
    "prettier": "3.8.1",
    "typescript-eslint": "^8.57.2"
  }
}
