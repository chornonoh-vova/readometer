{
  "name": "api",
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "dev": "bun --watch src/index.ts",
    "db:migrate": "kysely migrate",
    "db:generate": "kysely-codegen --out-file ./src/lib/db.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fmt": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "catalog:",
    "hono": "^4.12.18",
    "isbn": "workspace:*",
    "kysely": "^0.28.17",
    "pg": "^8.20.0",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.21.0",
    "prettier": "catalog:",
    "testcontainers": "^11.14.0",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
