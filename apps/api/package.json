{
  "name": "api",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "start": "NODE_ENV=production bun src/index.ts",
    "healthcheck": "bun src/healthcheck.ts",
    "dev": "bun --watch src/index.ts",
    "db:migrate": "kysely migrate",
    "db:generate": "kysely-codegen --out-file ./src/lib/db.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fmt": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "better-auth": "catalog:",
    "hono": "^4.12.27",
    "isbn": "workspace:*",
    "kysely": "^0.29.2",
    "pg": "^8.22.0",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@testcontainers/postgresql": "^12.0.3",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.21.0",
    "prettier": "catalog:",
    "testcontainers": "^12.0.1",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
