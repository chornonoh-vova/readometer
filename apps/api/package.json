{
  "name": "api",
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist --external=sharp",
    "dev": "bun --watch src/index.ts",
    "db:migrate": "kysely migrate",
    "db:generate": "kysely-codegen --out-file ./src/lib/db.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fmt": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.6.9",
    "hono": "^4.12.17",
    "isbn": "workspace:*",
    "kysely": "^0.28.17",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bun": "^1.3.13",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.20.0",
    "prettier": "3.8.3",
    "testcontainers": "^11.14.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
